# Docker image — managed by CI/CD pipeline (do not edit manually in production)
DOCKER_USERNAME=yourdockerhubusername
IMAGE_TAG=latest

NODE_ENV=development
PORT=8100

# PostgreSQL — password for notification_svc user (host/db fixed: pgbouncer:6432/notification_db)
DB_PASSWORD=change_me

# RabbitMQ — credentials (host fixed: rabbitmq:5672)
RABBITMQ_USER=katisha
RABBITMQ_PASSWORD=change_me

# itecsms.rw SMS gateway
ITECSMS_API_KEY=your-api-key-here

# Resend email
RESEND_API_KEY=re_xxxxxxxxxxxx
MAIL_FROM=Katisha <no-reply@katisha.rw>
LOGO_URL=https://your-cdn-or-host.example.com/logo-white.png
