# Docker image — managed by CI/CD pipeline (do not edit manually in production)
DOCKER_USERNAME=yourdockerhubusername
IMAGE_TAG=latest

NODE_ENV=development
PORT=8100

# PostgreSQL via pgbouncer
DATABASE_URL=postgresql://notification_svc:change_me@pgbouncer:6432/notification_db?pgbouncer=true&connect_timeout=5&pool_timeout=5

# RabbitMQ
RABBITMQ_URL=amqp://katisha:change_me@rabbitmq:5672

# bulksms.rw SMS gateway
BULKSMS_API_KEY=your-api-key-here
BULKSMS_SENDER_ID=KATISHA

# Resend email
RESEND_API_KEY=re_xxxxxxxxxxxx
MAIL_FROM=Katisha <no-reply@katisha.rw>
